<%# Shared marketing nav — rendered by both home.html.erb and pricing.html.erb.
    Section anchors are root_path-qualified so they work identically from any
    marketing page, not just the one that owns the matching id. %>
<nav class="nav">
  <div class="wrap nav__row">
    <%= link_to root_path, class: "brand" do %>Stablemate<span class="dot">.</span><% end %>
    <div class="nav__links">
      <a href="<%= root_path %>#how">How it works</a>
      <a href="<%= root_path %>#spec">recurring.yml</a>
      <a href="<%= root_path %>#mail">The email</a>
      <%= link_to "Pricing", pricing_path %>
      <a href="https://github.com/chrisjgilbert/stablemate/blob/main/docs/integrating.md">Docs</a>
    </div>
    <div class="nav__cta">
      <%= link_to "Sign in", sign_in_path, class: "signin" %>
      <%= link_to sign_up_path, class: "btn btn--primary" do %>Start free <span class="arw">→</span><% end %>
    </div>
  </div>
</nav>
