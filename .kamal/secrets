# Secrets referenced by config/deploy.yml (registry/password, env/secret,
# proxy/ssl, accessories/*/env/secret). All values are pulled from a password
# manager, ENV, or a local file — NEVER raw credentials. This file is safe for git.
#
# Recommended: pull from a password manager. Example with 1Password:
#   SECRETS=$(kamal secrets fetch --adapter 1password --account your-account \
#     --from Vault/Stablemate KAMAL_REGISTRY_PASSWORD RAILS_MASTER_KEY STABLEMATE_DATABASE_PASSWORD)
#   KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})
#   RAILS_MASTER_KEY=$(kamal secrets extract RAILS_MASTER_KEY ${SECRETS})
#   STABLEMATE_DATABASE_PASSWORD=$(kamal secrets extract STABLEMATE_DATABASE_PASSWORD ${SECRETS})

# --- Container registry -------------------------------------------------------
# Use an access token, not your account password. Grab it from ENV at deploy time:
#   export KAMAL_REGISTRY_PASSWORD=...
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# --- Rails master key ---------------------------------------------------------
# Decrypts config/credentials.yml.enc (secret_key_base + SMTP creds). Never commit
# config/master.key. On the deploy machine it's read from the (gitignored) file;
# in GitHub Actions there is no file, so it falls back to an already-set
# RAILS_MASTER_KEY env (the repo secret). File-first, env fallback.
#
# NB: the whole value is ONE $(...) command substitution on purpose. Kamal parses
# this file with dotenv, which runs $(...) in a real shell but does NOT understand
# bash's ${VAR:-default} operator — a `${RAILS_MASTER_KEY:-$(cat …)}` form leaves
# the literal `:-` and `}` in the value, producing a malformed key and a boot-time
# "key must be 16 bytes". Keep the fallback inside the $(...).
RAILS_MASTER_KEY=$(cat config/master.key 2>/dev/null || printf %s "$RAILS_MASTER_KEY")

# --- Database password --------------------------------------------------------
# One source of truth, used by BOTH the app (STABLEMATE_DATABASE_PASSWORD) and the
# Postgres accessory (POSTGRES_PASSWORD) so they can never drift. Set it in ENV:
#   export STABLEMATE_DATABASE_PASSWORD=...
STABLEMATE_DATABASE_PASSWORD=$STABLEMATE_DATABASE_PASSWORD
POSTGRES_PASSWORD=$STABLEMATE_DATABASE_PASSWORD

# --- Cloudflare Origin Certificate (kamal-proxy custom TLS cert) ---------------
# deploy.yml's proxy.ssl serves this cert. Generate a free 15-year Origin
# Certificate in the Cloudflare dashboard (SSL/TLS → Origin Server → Create
# Certificate) and save the two PEM blocks to these gitignored files on the deploy
# machine, then set Cloudflare SSL/TLS mode to "Full (strict)":
#   .kamal/cloudflare-origin.pem   (the certificate)
#   .kamal/cloudflare-origin.key   (the private key)
# (Switched deploy.yml to Let's Encrypt `ssl: true` instead? Comment these out.)
#
# File-first, env fallback (same single-$(...) form as RAILS_MASTER_KEY, and for the
# same dotenv reason — ${VAR:-…} is not parseable): on your laptop the PEMs are read
# from the gitignored files; GitHub Actions has none, so the STABLEMATE_SSL_CERT /
# STABLEMATE_SSL_KEY repo secrets take over.
STABLEMATE_SSL_CERT=$(cat .kamal/cloudflare-origin.pem 2>/dev/null || printf %s "$STABLEMATE_SSL_CERT")
STABLEMATE_SSL_KEY=$(cat .kamal/cloudflare-origin.key 2>/dev/null || printf %s "$STABLEMATE_SSL_KEY")
