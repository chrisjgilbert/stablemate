<!DOCTYPE html>
<html>
  <head>
    <%= render "layouts/head" %>

    <%# The "Omakase" marketing typefaces (Zilla Slab display, Newsreader reading
        serif, IBM Plex Mono for data). Scoped to the marketing page so the
        authenticated app keeps its system-ui fallback and no external request. %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Newsreader:ital,wght@0,400;0,500;1,400&family=Zilla+Slab:wght@600;700&display=swap" rel="stylesheet">

    <%# All marketing CSS is scoped under `.lp` (see the wrapper below) so the
        authenticated app's design tokens are untouched. %>
    <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-app text-ink font-sans antialiased min-h-screen overflow-x-hidden">
    <% if notice %>
      <div class="rounded-none border-b border-up-bg bg-up-bg/60 px-4 py-2.5 text-center text-[13px] text-up-text" role="status">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="rounded-none border-b border-down-bg bg-down-bg/60 px-4 py-2.5 text-center text-[13px] text-down-text" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <div class="lp"><%= yield %></div>
  </body>
</html>
