<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Stablemate" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Stablemate">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-app text-ink font-sans antialiased min-h-screen">
    <% if authenticated? %>
      <header class="border-b border-border bg-surface">
        <div class="max-w-5xl mx-auto px-5 h-14 flex items-center justify-between">
          <%= link_to root_path, class: "flex items-center gap-2" do %>
            <%= render "shared/logo" %>
            <span class="font-semibold tracking-tight">Stablemate</span>
          <% end %>
          <div class="flex items-center gap-1">
            <%= link_to "API keys", settings_api_keys_path,
                  class: "h-8 px-3 inline-flex items-center rounded-lg text-[13px] font-semibold text-secondary hover:bg-hairline" %>
            <%= button_to "Sign out", session_path, method: :delete,
                  class: "h-8 px-3 rounded-lg text-[13px] font-semibold text-secondary hover:bg-hairline" %>
          </div>
        </div>
      </header>
    <% end %>

    <main class="max-w-5xl mx-auto px-5 py-10">
      <% if notice %>
        <div class="mb-5 rounded-lg border border-up-bg bg-up-bg/60 px-4 py-2.5 text-[13px] text-up-text" role="status">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-5 rounded-lg border border-down-bg bg-down-bg/60 px-4 py-2.5 text-[13px] text-down-text" role="alert">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
