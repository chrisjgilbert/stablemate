<div class="rounded-xl border border-border bg-surface p-10 shadow-sm text-center max-w-xl mx-auto"
     data-testid="empty-state">
  <div class="flex justify-center mb-4"><%= render "shared/logo", size: 44 %></div>
  <h2 class="font-display text-lg font-bold tracking-tight">Monitor your first cron job</h2>
  <p class="mt-1 text-[13px] text-muted">
    Add a monitor and we'll alert you the moment a scheduled job stops checking in.
  </p>

  <div class="mt-5 flex items-center justify-center gap-3">
    <%= link_to "Add your first monitor", new_monitor_path,
          class: "inline-flex items-center h-9 px-4 rounded-lg bg-brand text-white text-[13px] font-semibold hover:bg-brand-hover" %>
    <%= link_to "Read the docs", "#",
          class: "inline-flex items-center h-9 px-4 rounded-lg border border-border text-[13px] font-semibold text-secondary hover:bg-hairline" %>
  </div>

  <div class="mt-8 text-left">
    <p class="text-[11px] font-semibold uppercase tracking-wide text-gem mb-2">Install the gem</p>
    <%= render "shared/recurring_yml_snippet" %>
    <p class="mt-2 text-[12px] text-muted">
      Add the gem and your recurring jobs register themselves — no per-job code.
      <%= link_to "Install the gem →", "#", class: "text-brand font-medium" %>
    </p>
  </div>
</div>
