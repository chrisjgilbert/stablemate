<%#
  Detail recent-events list (design-system.md §3): most-recent pings + incident
  open/resolve events, newest first. Mono timestamps; duration_ms shown when
  present; active incident (the open down event) leads.
  Locals: monitor.
%>
<div class="rounded-xl border border-border bg-surface p-6 shadow-sm" data-testid="recent-events">
  <h2 class="text-[13px] font-semibold text-secondary mb-4">Recent events</h2>
  <% events = monitor.recent_events %>
  <% if events.any? %>
    <ul class="divide-y divide-hairline text-[12px] font-mono text-secondary">
      <% events.each do |event| %>
        <li class="py-2 flex items-center justify-between gap-4">
          <span class="flex items-center gap-2 min-w-0">
            <% dot = case event.kind
                     when :down then "bg-down-dot"
                     when :recovered then "bg-up-dot"
                     else "bg-paused-dot"
                     end %>
            <span class="w-1.5 h-1.5 rounded-full shrink-0 <%= dot %>"></span>
            <span class="truncate"><%= event.label %></span>
            <% if event.duration_ms.present? %>
              <span class="text-muted" data-testid="event-duration"><%= event.duration_ms %>ms</span>
            <% end %>
          </span>
          <span class="text-muted shrink-0"><%= mono_timestamp(event.at, seconds: true) %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-[13px] text-muted">No events yet.</p>
  <% end %>
</div>
