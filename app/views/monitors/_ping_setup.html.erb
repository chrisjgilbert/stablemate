<%# locals: (monitor:, collapsed: false) %>
<%#
  Ping URL card: copyable ping URL + curl snippet + rotate. Setup is a one-time
  concern, so show.html.erb renders this two ways:
  - unwrapped (collapsed: false) near the top while wiring up is the user's
    next step: a never-pinged manual monitor, or the one render right after a
    token rotation (the old URL just died; the new one must be seen).
  - a closed <details> disclosure (collapsed: true) at the bottom otherwise,
    so it stops crowding the triage view.
%>
<% rotate_button = button_to("Rotate token", monitor_ping_token_path(monitor), method: :patch,
     form: { data: { turbo_confirm: "Rotate the token? The current ping URL stops working immediately." } },
     class: "h-7 px-2.5 rounded-lg border border-border text-[12px] font-semibold text-secondary hover:bg-hairline") %>

<% fields = capture do %>
  <%= render "shared/copyable", value: ping_url_for(monitor), label: "Ping URL" %>
  <div>
    <p class="text-[12px] text-muted mb-1">Wire it into your job:</p>
    <%= render "shared/copyable", value: curl_snippet_for(monitor), dark: true, label: "curl snippet" %>
  </div>
<% end %>

<% if collapsed %>
  <details data-testid="ping-url-card" class="rounded-xl border border-border bg-surface shadow-sm">
    <summary class="cursor-pointer select-none px-6 py-4 text-[13px] font-semibold text-secondary">
      Ping URL &amp; setup
    </summary>
    <div class="px-6 pb-6 space-y-4">
      <div class="flex justify-end"><%= rotate_button %></div>
      <%= fields %>
    </div>
  </details>
<% else %>
  <div class="rounded-xl border border-border bg-surface p-6 shadow-sm space-y-4" data-testid="ping-url-card">
    <div class="flex items-center justify-between">
      <h2 class="text-[13px] font-semibold text-secondary">Ping URL</h2>
      <%= rotate_button %>
    </div>
    <%= fields %>
  </div>
<% end %>
