<%#
  Keystone logo (design-system.md §2): warm-dark tile + Rails-red keystone glyph.
  size: tile px (default 26); glyph scales proportionally.
%>
<% size ||= 26 %>
<span class="inline-flex items-center justify-center bg-warmdark rounded-[7px]"
      style="width: <%= size %>px; height: <%= size %>px;">
  <svg width="<%= (size * 0.54).round %>" height="<%= (size * 0.54).round %>" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M8.4 4h7.2l3.4 16H5z" fill="#C5361F"></path>
  </svg>
</span>
