<% content_for :title, @waitlist ? "Join the waitlist" : "Sign up" %>
<div class="max-w-sm mx-auto mt-8">
  <div class="flex flex-col items-center gap-2 mb-8 text-center">
    <%= render "shared/logo", size: 40 %>
    <% if @waitlist %>
      <h1 class="text-2xl font-semibold tracking-tight">Join the waitlist</h1>
      <p class="text-[13px] text-muted">We're at capacity right now. Leave your email and we'll send an invite.</p>
    <% else %>
      <h1 class="text-2xl font-semibold tracking-tight">Create your account</h1>
      <p class="text-[13px] text-muted">Free — <%= free_plan_monitors_phrase %></p>
    <% end %>
  </div>

  <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
    <% if @waitlist %>
      <%= render "shared/form_errors", record: @waitlist_signup %>

      <%= form_with url: sign_up_path, class: "space-y-4", data: { testid: "waitlist-form" } do |form| %>
        <div>
          <%= form.label :email_address, "Email", class: "block text-[13px] font-medium text-secondary mb-1" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
                class: "w-full h-[38px] px-3 rounded-lg border border-border font-mono text-[13px] focus:outline-brand" %>
        </div>
        <%= form.submit "Join the waitlist",
              class: "w-full h-[38px] rounded-lg bg-brand text-white text-[13px] font-semibold hover:bg-brand-hover cursor-pointer" %>
      <% end %>
    <% else %>
      <%= render "shared/form_errors", record: @user %>

      <%= form_with url: sign_up_path, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :email_address, "Email", class: "block text-[13px] font-medium text-secondary mb-1" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
                value: @user&.email_address,
                class: "w-full h-[38px] px-3 rounded-lg border border-border font-mono text-[13px] focus:outline-brand" %>
        </div>
        <div>
          <%= form.label :password, "Password", class: "block text-[13px] font-medium text-secondary mb-1" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72,
                class: "w-full h-[38px] px-3 rounded-lg border border-border text-[13px] focus:outline-brand" %>
        </div>
        <div>
          <%= form.label :password_confirmation, "Confirm password", class: "block text-[13px] font-medium text-secondary mb-1" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72,
                class: "w-full h-[38px] px-3 rounded-lg border border-border text-[13px] focus:outline-brand" %>
        </div>
        <%= form.submit "Create account",
              class: "w-full h-[38px] rounded-lg bg-brand text-white text-[13px] font-semibold hover:bg-brand-hover cursor-pointer" %>
      <% end %>
    <% end %>
  </div>

  <p class="mt-5 text-center text-[13px] text-secondary">
    Already have an account? <%= link_to "Sign in", sign_in_path, class: "text-brand font-medium" %>
  </p>
</div>
