# Stablemate self-hosting configuration.
#
# Copy this file to `.env` and fill in the values, then `docker compose up`.
#   cp .env.example .env
#
# `.env` is gitignored — keep your real secrets out of version control.
# Every value below is read by the app at boot via the environment; there are NO
# in-repo Rails credentials to manage. (`config/master.key` is not needed.)

# ──────────────────────────────────────────────────────────────────────────────
# Core — required
# ──────────────────────────────────────────────────────────────────────────────

# Your instance's public hostname (no scheme, no trailing slash). Ping URLs and
# all email links are built from this, so it MUST be the domain your monitored
# jobs and your browser actually reach.
STABLEMATE_HOST=stablemate.example.com

# http or https. Use https in production (behind a TLS-terminating proxy). For a
# quick local trial over plain HTTP, set this to http AND STABLEMATE_FORCE_SSL=false.
STABLEMATE_PROTOCOL=https

# Force HTTPS + HSTS + Secure cookies. Keep this true in production. Set false
# only if you terminate TLS elsewhere and proxy plain HTTP, or for a local trial.
STABLEMATE_FORCE_SSL=true

# Secret used to sign cookies/sessions. Generate a fresh one — NEVER reuse this
# example. Run:  docker compose run --rm web bin/rails secret
# (or: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)')
SECRET_KEY_BASE=change-me-run-bin-rails-secret

# ──────────────────────────────────────────────────────────────────────────────
# Database — required
# ──────────────────────────────────────────────────────────────────────────────
# These are consumed BOTH by the Postgres container (to create the role/db) and
# by the Rails app (to connect), so the two can never drift. DB_HOST is forced to
# the compose service name by docker-compose.yml regardless of what you put here.
# The app derives the Solid Cache/Queue/Cable database names from POSTGRES_DB
# (e.g. <POSTGRES_DB>_cache).
POSTGRES_DB=stablemate_production
DB_USERNAME=stablemate
DB_PASSWORD=change-me-strong-db-password
DB_HOST=postgres
DB_PORT=5432

# ──────────────────────────────────────────────────────────────────────────────
# SMTP — required for down/recovery alert emails
# ──────────────────────────────────────────────────────────────────────────────
# Point at your own SMTP provider (Postmark, SES, Mailgun, Fastmail, …). Without
# this, the app boots fine but cannot send alert emails. Leave SMTP_USERNAME and
# SMTP_PASSWORD blank for an unauthenticated relay (e.g. a local Postfix or an
# internal SMTP that authorises by IP) — AUTH is only used when a username is set.
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=change-me-smtp-password
SMTP_DOMAIN=example.com
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS=true

# The From / Reply-To addresses on alert emails. Use a sender your SMTP provider
# is authorised to send as (SPF/DKIM aligned) or your mail lands in spam.
STABLEMATE_MAIL_FROM="Stablemate <alerts@example.com>"
STABLEMATE_MAIL_REPLY_TO=support@example.com

# ──────────────────────────────────────────────────────────────────────────────
# Caps & waitlist — optional (issue #16). Unset = unlimited / no waitlist.
# ──────────────────────────────────────────────────────────────────────────────
# Self-hosters normally leave these unset (no limits). The managed instance sets
# them to gate free usage.
# STABLEMATE_MAX_MONITORS_PER_USER=
# STABLEMATE_SIGNUP_ACCOUNT_CAP=

# ──────────────────────────────────────────────────────────────────────────────
# Slack — optional
# ──────────────────────────────────────────────────────────────────────────────
# Posts a message to this Slack incoming webhook whenever a new account signs
# up. Leave unset to disable (default — self-hosters don't need this).
# SLACK_WEBHOOK_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Billing (Stripe) — optional (issue #19). Unset = billing OFF, everyone Free.
# ──────────────────────────────────────────────────────────────────────────────
# The hosted "Pro plan" surface stays fully dark unless ALL THREE of the keys
# below are set — publishable + secret + webhook signing secret. Miss any one and
# the whole /billing namespace answers an opaque 404, Pay stays dormant, and every
# user is on Free. Self-hosters normally leave this off. Get the keys from your
# Stripe Dashboard (Developers → API keys) and add a webhook endpoint pointing at
# https://<STABLEMATE_HOST>/billing/webhook — its signing secret is STRIPE_WEBHOOK_SECRET.
#
# Live vs test mode is derived from the secret-key prefix (sk_live_/sk_test_), and
# webhook events from the OTHER mode are rejected even when correctly signed — so
# all four values below must be from the SAME Stripe mode.
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# The Stripe Price ID the Upgrade button charges against — create a "Pro" product
# with a recurring monthly price and paste its price_... id here. Without it,
# checkout redirects back with "Pro plan isn't configured." Annual is a future
# seam: set STRIPE_PRICE_ID_PRO_ANNUAL to a second Price ID later (V1 is monthly).
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_PRO_ANNUAL=price_...

# ──────────────────────────────────────────────────────────────────────────────
# Advanced — optional
# ──────────────────────────────────────────────────────────────────────────────
# Extra Host headers to accept besides STABLEMATE_HOST (comma-separated).
# STABLEMATE_HOSTS=www.stablemate.example.com,internal.lan
# Running behind a reverse proxy / CDN? Tell the app which upstreams to trust so
# the real client IP survives (ping rate limiting + session log). Leave both unset
# if the app is reached directly — trusting a forwarded IP you can't vouch for lets
# clients spoof their source address.
#   Behind Cloudflare: STABLEMATE_BEHIND_CLOUDFLARE=true (trusts Cloudflare's ranges)
# STABLEMATE_BEHIND_CLOUDFLARE=true
#   Behind your own proxy/LB: list its CIDRs (comma-separated).
# STABLEMATE_TRUSTED_PROXIES=10.0.0.0/8,192.168.1.5/32
# Rails log level (debug logs may include PII).
# RAILS_LOG_LEVEL=info
# Threads per Puma worker (also the DB connection pool size).
# RAILS_MAX_THREADS=5
