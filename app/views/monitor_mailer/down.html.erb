<h1 style="font-family: sans-serif; color: #c0282d;">Your monitor is down</h1>

<p style="font-family: sans-serif; color: #26262c;">
  <strong style="font-family: monospace;"><%= @monitor.name %></strong>
  has missed its expected check-in and is now marked <strong>down</strong>.
</p>

<% if @expected_by %>
  <p style="font-family: sans-serif; color: #62626c;">
    Expected by
    <span style="font-family: monospace;"><%= @expected_by.utc.strftime("%Y-%m-%d %H:%M UTC") %></span>,
    but no ping arrived.
  </p>
<% end %>

<p style="font-family: sans-serif;">
  <%= link_to "View monitor", monitor_url(@monitor), style: "color: #5b53eb;" %>
</p>
