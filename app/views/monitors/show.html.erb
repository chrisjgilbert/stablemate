<% content_for :title, @monitor.name %>
<% open_incident = @monitor.open_incident %>
<%# Setup is a one-time concern: collapse it to the bottom once the monitor is
    live, immediately for a gem-registered one (the gem gets its ping URL from
    the API sync, never from this card), and for a suspended one (a swallowed
    ping can't reactivate it, so "wire it into your job" would be a false
    promise). Exception: right after a token rotation the controller sets
    flash[:reveal_ping_setup], and the full card comes back to the top for that
    one render — the old URL just died and the new one must be seen. (An
    anchored redirect can't do this job: Turbo follows form redirects via
    fetch, which drops the URL fragment, so the browser never scrolls.) %>
<% ping_setup_collapsed =
     (@monitor.ever_pinged? || @monitor.from_gem? || @monitor.suspended?) &&
     !flash[:reveal_ping_setup] %>

<%# Live status: subscribe to the monitor's stream so broadcast_status_update's
    :badge replace lands on the header badge without a reload (mirrors _row.html.erb). %>
<%= turbo_stream_from @monitor %>

<div class="max-w-3xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <%= link_to "← Monitors", monitors_path, class: "text-[13px] text-muted hover:text-ink" %>
      <h1 class="font-mono text-lg text-ink"><%= @monitor.name %></h1>
      <%= render "monitors/badge", monitor: @monitor %>
      <%= render "shared/gem_chip", monitor: @monitor, variant: :full %>
    </div>
    <div class="flex items-center gap-2">
      <%# Pause/Resume is user-driven monitoring control. A `suspended` monitor
          (plan-downgrade, issue #19) has no pause/resume affordance: it can't be
          resumed without re-upgrading, and pausing it would flip it to `paused`,
          which DOES count toward the cap — letting a downgraded user quietly push
          suspended monitors back into their cap. So hide it entirely when suspended. %>
      <% unless @monitor.suspended? %>
        <% if @monitor.paused? %>
          <%= button_to "Resume", monitor_pause_path(@monitor), method: :delete,
                class: "h-8 px-3 rounded-lg border border-border text-[13px] font-semibold text-secondary hover:bg-hairline" %>
        <% else %>
          <%= button_to "Pause", monitor_pause_path(@monitor), method: :post,
                class: "h-8 px-3 rounded-lg border border-border text-[13px] font-semibold text-secondary hover:bg-hairline" %>
        <% end %>
      <% end %>
      <%= link_to "Edit", edit_monitor_path(@monitor),
            class: "h-8 px-3 inline-flex items-center rounded-lg border border-border text-[13px] font-semibold text-secondary hover:bg-hairline" %>
      <%= button_to "Delete", monitor_path(@monitor), method: :delete,
            form: { data: { turbo_confirm: "Delete this monitor and all its data?" } },
            class: "h-8 px-3 rounded-lg text-[13px] font-semibold text-down-text hover:bg-down-bg/60" %>
    </div>
  </div>

  <% if open_incident %>
    <%# Active-incident banner (spec §3.4 + job-failure-details.md §9): red,
        pulsing down dot, cause-aware copy in ONE shell — only the heading
        tail, the error block, and the expected-by/grace rows vary by cause.
        NO Acknowledge button — incidents are open/resolved only, resolved by
        a recovering ping.
        - missed_ping: expected-by / grace elapsed / down for. Expected-by is
          the incident's START (the moment the grace window elapsed), not the
          live due_with_grace_at — a failure ping on an already-down monitor
          advances next_due_at, which would render a nonsensical FUTURE
          "expected by" on an active outage.
        - reported_error: the error itself instead of expected-by/grace
          (nothing was late — the job ran and said so). %>
    <div class="rounded-xl border border-down-dot bg-down-bg p-5" data-testid="incident-banner">
      <h3 class="flex items-center gap-2 font-display text-base font-bold text-down-text">
        <span class="w-2 h-2 rounded-full bg-down-dot status-dot-pulse"></span>
        Monitor is down — <%= open_incident.reported_error? ? "the job reported an error" : "no ping received" %>
      </h3>
      <% if open_incident.reported_error? %>
        <p class="mt-2 max-w-md rounded-lg border border-down-dot/40 px-3 py-2 font-mono text-[13px] text-down-text break-words" data-testid="incident-error"><%= open_incident.error %></p>
      <% end %>
      <dl class="mt-2 grid grid-cols-2 gap-y-1 text-[13px] text-down-text font-mono max-w-md">
        <% unless open_incident.reported_error? %>
          <dt>Expected by</dt>
          <dd data-testid="expected-by"><%= mono_timestamp(open_incident.started_at) %></dd>
          <dt>Grace</dt>
          <dd data-testid="grace-elapsed"><%= humanize_seconds(@monitor.grace_period_seconds) %> elapsed</dd>
        <% end %>
        <dt>Down for</dt>
        <dd data-testid="down-for"><%= distance_of_time_in_words(open_incident.started_at, Time.current) %></dd>
      </dl>
    </div>
  <% end %>

  <%# Ping URL card + curl snippet — full and visible here only while the
      monitor still needs wiring up; see ping_setup_collapsed above. %>
  <% unless ping_setup_collapsed %>
    <%= render "monitors/ping_setup", monitor: @monitor %>
  <% end %>

  <%# Settings summary %>
  <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
    <h2 class="text-[13px] font-semibold text-secondary mb-4">Settings</h2>
    <dl class="grid grid-cols-2 gap-y-3 text-[13px]">
      <dt class="text-muted">Status</dt><dd><%= render "shared/status_badge", status: @monitor.status %></dd>
      <dt class="text-muted">Expected interval</dt><dd class="font-mono"><%= humanize_seconds(@monitor.expected_interval_seconds) %></dd>
      <dt class="text-muted">Grace period</dt><dd class="font-mono"><%= humanize_seconds(@monitor.grace_period_seconds) %></dd>
      <dt class="text-muted">Last ping</dt>
      <dd class="font-mono"><%= mono_timestamp(@monitor.last_ping_at) %></dd>
      <%# The down case is already covered by "Expected by" in the incident
          banner above. %>
      <%= render "monitors/next_check", monitor: @monitor, variant: :dl %>
    </dl>
  </div>

  <%# Which project this monitor lives in + the move control (manual monitors only). %>
  <%= render "monitors/move", monitor: @monitor %>

  <%# 90-day uptime history (real rollup data) + the recent-events feed. %>
  <%= render "monitors/uptime_panel", monitor: @monitor %>
  <%= render "monitors/recent_events", monitor: @monitor %>

  <%# Collapsed setup, once live. %>
  <% if ping_setup_collapsed %>
    <%= render "monitors/ping_setup", monitor: @monitor, collapsed: true %>
  <% end %>
</div>
