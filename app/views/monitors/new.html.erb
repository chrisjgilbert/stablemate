<% content_for :title, "New monitor" %>
<div class="max-w-xl mx-auto">
  <h1 class="font-display text-xl font-bold tracking-tight mb-6">New monitor</h1>

  <% if current_user.at_monitor_cap? %>
    <%# At-limit state (phase-4 §3.2): matter-of-fact note, no upgrade/pricing UI. %>
    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm" data-testid="at-limit-note">
      <p class="text-[14px] font-semibold text-ink mb-1">You're at the monitor limit</p>
      <p class="text-[13px] text-muted leading-relaxed">
        <%= monitor_limit_note(current_user) %>
        Delete a monitor to free up a slot, then come back to add another.
      </p>
      <%= link_to "Back to monitors", monitors_path,
            class: "inline-flex items-center h-8 px-3 mt-4 rounded-lg border border-border text-[13px] font-semibold text-secondary hover:bg-hairline" %>
    </div>
  <% else %>
    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
      <%= render "monitors/form", monitor: @monitor %>
    </div>
  <% end %>
</div>
