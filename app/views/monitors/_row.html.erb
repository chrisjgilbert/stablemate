<%#
  A single dashboard monitor row. Wrapped so the live-status broadcast
  (monitor.broadcast_status_update) can replace just this fragment over Solid
  Cable: it subscribes to the monitor's stream and the outer id matches the
  broadcast target (dom_id(monitor, :row)).
%>
<%= turbo_stream_from monitor %>
<%# `relative` anchors the stretched link below so the whole row is one click
    target into the monitor; the name stays the accessible link text. %>
<div id="<%= dom_id(monitor, :row) %>" class="relative flex items-center justify-between px-[18px] py-[13px] hover:bg-surface-subtle">
  <div class="flex items-center gap-3 min-w-0">
    <%= render "shared/status_badge", status: monitor.status %>
    <%# before:absolute before:inset-0 stretches the link over the entire row, so
        clicking anywhere on the row opens the monitor — not just the name. %>
    <%= link_to monitor.name, monitor_path(monitor),
          class: "font-mono text-[13px] text-ink truncate hover:text-brand before:absolute before:inset-0" %>
    <%= render "shared/gem_chip", monitor: monitor, variant: :compact %>
  </div>
  <div class="flex items-center gap-4 text-[12px] text-muted shrink-0">
    <%# Last-16-checks sparkline + uptime % (Phase 2). The index preloads ticks
        for all rows in one query (no N+1); a single-row Turbo broadcast omits the
        local and falls back to the per-monitor lookup. %>
    <% ticks = monitor.mini_ticks(kinds: local_assigns[:mini_ticks]) %>
    <span data-testid="mini-ticks"><%= render "shared/mini_ticks", checks: ticks %></span>
    <span class="font-mono">every <%= humanize_seconds(monitor.expected_interval_seconds) %></span>
    <span class="font-mono">
      <%= monitor.last_ping_at ? "#{time_ago_in_words(monitor.last_ping_at)} ago" : "never pinged" %>
    </span>
  </div>
</div>
