<!DOCTYPE html>
<html>
  <head>
    <%= render "layouts/head" %>
  </head>

  <body class="bg-app text-ink font-sans antialiased min-h-screen">
    <% if authenticated? %>
      <%# Active-section underline: match on controller so the current nav item
          gets a red underline (per the mockup). %>
      <% section = controller_path %>
      <% nav_link = ->(label, path, active) {
           link_to label, path,
             class: "h-14 inline-flex items-center font-mono text-[13px] border-b-2 " +
                    (active ? "text-ink border-brand" : "text-secondary border-transparent hover:text-ink") } %>
      <header class="border-b border-border bg-surface">
        <div class="max-w-5xl mx-auto px-5 h-14 flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <%= link_to root_path, class: "font-display text-lg font-bold tracking-tight text-ink" do %>
              Stablemate<span class="text-brand">.</span>
            <% end %>
            <%= render "shared/coming_soon_badge" %>
          </div>
          <nav class="flex items-center gap-5">
            <%= nav_link.call("Monitors", monitors_path, section == "monitors") %>
            <%# API keys live under each project now (Design B) — reach them from a
                project's page, so the nav points at Projects, not a standalone screen. %>
            <%= nav_link.call("Projects", projects_path, section == "projects") %>
            <% if billing_enabled? %>
              <%= link_to "Billing", billing_subscription_path,
                    class: "h-14 inline-flex items-center font-mono text-[13px] border-b-2 " +
                           (section.start_with?("billing/") ? "text-ink border-brand" : "text-secondary border-transparent hover:text-ink"),
                    data: { testid: "nav-billing" } %>
            <% end %>
            <%= button_to "Sign out", session_path, method: :delete,
                  class: "h-14 inline-flex items-center font-mono text-[13px] text-secondary hover:text-ink" %>
          </nav>
        </div>
      </header>
    <% end %>

    <main class="max-w-5xl mx-auto px-5 py-10">
      <%# Account-wide involuntary-downgrade grace banner (§7/§12-J): monitors keep
          running, but the user must pick which N to keep by the deadline. Gated on
          the hosted tier being live, so a self-host instance never sees it. %>
      <% if authenticated? && billing_enabled? && current_user.must_choose_downgrade? %>
        <%= render "shared/downgrade_grace_banner" %>
      <% end %>

      <% if notice %>
        <div class="mb-5 rounded-lg border border-up-bg bg-up-bg/60 px-4 py-2.5 text-[13px] text-up-text" role="status">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-5 rounded-lg border border-down-bg bg-down-bg/60 px-4 py-2.5 text-[13px] text-down-text" role="alert">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
