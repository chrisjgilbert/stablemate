<% content_for :title, @project.name %>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3 min-w-0">
    <%= link_to "Projects", projects_path, class: "text-[13px] text-muted hover:text-ink shrink-0" %>
    <span class="text-muted shrink-0">/</span>
    <h1 class="font-display text-xl font-bold tracking-tight truncate"><%= @project.name %></h1>
  </div>
  <div class="flex items-center gap-2 shrink-0">
    <%= link_to "New monitor", new_monitor_path(monitor: { project_id: @project.id }),
          class: "inline-flex items-center h-8 px-3 rounded-lg bg-brand text-white text-[13px] font-semibold hover:bg-brand-hover" %>
    <%= link_to "Settings", edit_project_path(@project),
          class: "inline-flex items-center h-8 px-3 rounded-lg border border-border text-[13px] font-semibold text-secondary hover:bg-hairline" %>
  </div>
</div>

<% if @monitors.any? %>
  <%= render "monitors/list", monitors: @monitors, mini_ticks: @mini_ticks %>
<% else %>
  <div class="rounded-xl border border-border bg-surface p-10 text-center shadow-sm" data-testid="project-no-monitors">
    <p class="text-[14px] font-semibold text-ink">No monitors in this project yet</p>
    <p class="text-[13px] text-muted mt-1 mb-4">
      Add one manually, or connect the gem with this project's API key.
    </p>
    <%= link_to "Add a monitor", new_monitor_path(monitor: { project_id: @project.id }),
          class: "inline-flex items-center h-9 px-4 rounded-lg bg-brand text-white text-[13px] font-semibold hover:bg-brand-hover" %>
  </div>
<% end %>

<%= render "projects/api_keys", project: @project, api_keys: @api_keys %>

<% if @raw_token.present? %>
  <%= render "projects/generated_modal", raw_token: @raw_token %>
<% end %>
