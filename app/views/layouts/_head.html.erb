<title><%= content_for(:title) || "Stablemate" %></title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="application-name" content="Stablemate">
<meta name="mobile-web-app-capable" content="yes">
<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<%= yield :head %>

<link rel="icon" href="/icon.png" type="image/png">
<link rel="icon" href="/icon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/icon.png">

<%# :app bundles every top-level app/assets/stylesheets/*.css, including
    fonts.css — the self-hosted Omakase typefaces (Zilla Slab, IBM Plex Mono,
    Newsreader) shared by both layouts. No third-party font request at render
    time. %>
<%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
<%= javascript_importmap_tags %>
