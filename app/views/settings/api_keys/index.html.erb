<% content_for :title, "API keys" %>

<div class="max-w-3xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-semibold tracking-tight">API keys</h1>
      <p class="text-[13px] text-muted mt-1">
        Bearer tokens for the Stablemate gem and the <code class="font-mono">/api/v1</code> API.
      </p>
    </div>
    <%= render "settings/api_keys/generate_form", label: "Generate key", height: "h-8" %>
  </div>

  <% if @api_keys.any? %>
    <div class="rounded-xl border border-border bg-surface overflow-hidden shadow-sm">
      <table class="w-full text-[13px]" data-testid="api-keys-table">
        <thead class="text-left text-muted border-b border-hairline">
          <tr>
            <th class="px-4 py-2.5 font-medium">Name</th>
            <th class="px-4 py-2.5 font-medium">Key</th>
            <th class="px-4 py-2.5 font-medium">Created</th>
            <th class="px-4 py-2.5 font-medium">Last used</th>
            <th class="px-4 py-2.5"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-hairline">
          <% @api_keys.each do |key| %>
            <tr id="<%= dom_id(key) %>">
              <td class="px-4 py-3"><%= key.name %></td>
              <td class="px-4 py-3 font-mono text-muted"><%= key.masked %></td>
              <td class="px-4 py-3 font-mono text-muted"><%= mono_timestamp(key.created_at) %></td>
              <td class="px-4 py-3 font-mono text-muted"><%= mono_timestamp(key.last_used_at, blank: "never") %></td>
              <td class="px-4 py-3 text-right">
                <%= button_to "Revoke", settings_api_key_path(key), method: :delete,
                      form: { data: { turbo_confirm: "Revoke this key? Anything using it stops working immediately." } },
                      class: "h-7 px-2.5 rounded-lg text-[12px] font-semibold text-down-text hover:bg-down-bg/60" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-xl border border-border bg-surface p-10 text-center shadow-sm" data-testid="api-keys-empty">
      <p class="text-[14px] font-semibold text-ink">No API keys yet</p>
      <p class="text-[13px] text-muted mt-1 mb-4">
        Generate a key to register monitors from the Stablemate gem or call the API.
      </p>
      <%= render "settings/api_keys/generate_form", label: "Generate your first key", height: "h-9" %>
    </div>
  <% end %>
</div>

<% if @raw_token.present? %>
  <%= render "settings/api_keys/generated_modal", raw_token: @raw_token %>
<% end %>
