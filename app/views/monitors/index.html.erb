<% content_for :title, "Monitors" %>
<% count = @monitors.size # relation already loaded; no extra COUNT query %>
<% at_cap = current_user.at_monitor_cap? %>

<% if @projects.empty? %>
  <%# First run: no project yet, so onboard through project creation (§6, §13-S6). %>
  <%= render "projects/first_run" %>
<% else %>
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <h1 class="font-display text-xl font-bold tracking-tight">Monitors</h1>
      <span class="font-mono text-[13px] text-muted" data-testid="monitor-count">
        <%= current_user.monitor_limit ? "#{count} / #{current_user.monitor_limit}" : count %>
      </span>
    </div>

    <% if at_cap %>
      <span class="inline-flex items-center h-8 px-3 rounded-lg bg-hairline text-[13px] font-semibold text-muted cursor-not-allowed"
            title="<%= monitor_limit_note(current_user) %>"
            data-testid="at-limit">At monitor limit</span>
    <% else %>
      <%= link_to "New monitor", new_monitor_path,
            class: "inline-flex items-center h-8 px-3 rounded-lg bg-brand text-white text-[13px] font-semibold hover:bg-brand-hover" %>
    <% end %>
  </div>

  <%# User-level cap note (unchanged — the cap stays per-user, §7). %>
  <% if at_cap %>
    <% if current_user.can_upgrade_to_pro? %>
      <%# Hosted tier: the at-limit prompt is an upgrade nudge (PRD §5.6). %>
      <div class="mb-6 flex items-center gap-3 rounded-lg border border-border bg-surface px-4 py-3 shadow-sm" data-testid="at-limit-note">
        <p class="text-[13px] text-muted">
          You're at the <%= current_user.monitor_limit %>-monitor limit for the Free plan.
          Upgrade to Pro for up to <%= Stablemate::PRO_PLAN_MONITOR_LIMIT %>.
        </p>
        <%= button_to "Upgrade to Pro", billing_checkout_path,
              class: "ml-auto h-8 px-3 inline-flex items-center rounded-lg bg-brand text-white text-[13px] font-semibold hover:bg-brand-hover whitespace-nowrap",
              data: { testid: "upgrade-button" } %>
      </div>
    <% else %>
      <%# Self-host (or Pro at the 100 cap): matter-of-fact, nothing to upgrade to. %>
      <p class="mb-6 text-[13px] text-muted" data-testid="at-limit-note">
        <%= monitor_limit_note(current_user) %> Delete a monitor to add another.
      </p>
    <% end %>
  <% end %>

  <%# Group active monitors into one headed section per project that has active
      rows, reusing monitors/_list. Keyed on the project_id column (no association
      load), looked up against @projects (§6). %>
  <% active_by_project = @monitors.group_by(&:project_id) %>
  <% @projects.each do |project| %>
    <% rows = active_by_project[project.id] || [] %>
    <% next if rows.empty? %>
    <section class="mb-8" data-testid="project-group">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-[13px] font-semibold text-secondary">
          <%= link_to project.name, project_path(project), class: "hover:text-brand" %>
        </h2>
        <span class="font-mono text-[12px] text-muted"><%= rows.size %></span>
      </div>
      <% if at_cap %>
        <%# The account is at cap, so new gem jobs into this project are skipped (§13-S5). %>
        <%= render "monitors/cap_skip_banner", project: project %>
      <% end %>
      <%= render "monitors/list", monitors: rows, mini_ticks: @mini_ticks %>
    </section>
  <% end %>

  <% if @monitors.empty? && @suspended_monitors.empty? %>
    <%# Has a project but no monitors yet — the monitor-centric add-your-first CTA. %>
    <%= render "monitors/empty_state" %>
  <% end %>

  <% if @suspended_monitors.present? %>
    <%# Plan-suspended monitors (hosted tier): retained, not monitored, don't count
        toward the cap. Re-upgrading reactivates them. (PRD §3.3 / §5.6.) %>
    <div class="mt-8" data-testid="suspended-section">
      <h2 class="mb-2 text-[13px] font-semibold text-muted">Suspended <span class="font-mono">(<%= @suspended_monitors.size %>)</span></h2>
      <p class="mb-3 text-[12px] text-muted">Kept but not monitored after a plan downgrade. Upgrade to Pro to reactivate.</p>
      <%= render "monitors/list", monitors: @suspended_monitors, mini_ticks: @mini_ticks, card_class: "opacity-70" %>
    </div>
  <% end %>
<% end %>
