<% content_for :title, "Update password" %>
<div class="max-w-sm mx-auto mt-8">
  <div class="flex flex-col items-center gap-3 mb-8 text-center">
    <%= render "shared/logo", size: 40 %>
    <h1 class="font-display text-2xl font-bold tracking-tight">Update your password</h1>
  </div>

  <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
    <% if alert = flash[:alert] %>
      <div class="mb-4 rounded-lg border border-down-bg bg-down-bg/60 px-3 py-2 text-[12px] text-down-text" id="alert" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :password, "New password", class: "block text-[13px] font-medium text-secondary mb-1" %>
        <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password", maxlength: 72,
              class: "w-full h-[38px] px-3 rounded-lg border border-border text-[13px] focus:outline-brand" %>
      </div>
      <div>
        <%= form.label :password_confirmation, "Confirm password", class: "block text-[13px] font-medium text-secondary mb-1" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72,
              class: "w-full h-[38px] px-3 rounded-lg border border-border text-[13px] focus:outline-brand" %>
      </div>
      <%= form.submit "Save",
            class: "w-full h-[38px] rounded-lg bg-brand text-white text-[13px] font-semibold hover:bg-brand-hover cursor-pointer" %>
    <% end %>
  </div>

  <p class="mt-5 text-center text-[13px] text-secondary">
    <%= link_to "Back to sign in", sign_in_path, class: "text-brand font-medium" %>
  </p>
</div>
