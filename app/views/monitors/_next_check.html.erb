<%#
  "Next check". Shown only while genuinely upcoming (HeartbeatStates
  #next_check_upcoming?) — an up monitor can already be past next_due_at but
  still inside its grace window, where the timestamp is stale.
  variant: :row (dashboard row — a compact countdown, no grace clause; the
  row is already tight, and the full picture is one click away) or :dl
  (detail page — the exact timestamp, plus a grace-until note when a grace
  period is actually configured).
  Locals: monitor, variant (default :row).
%>
<% variant ||= :row %>
<% if monitor.next_check_upcoming? %>
  <% if variant == :dl %>
    <dt class="text-muted">Next check</dt>
    <dd class="font-mono" data-testid="next-check">
      <%= mono_timestamp(monitor.next_due_at) %>
      <% if monitor.grace_period_configured? %>
        <span class="text-muted" data-testid="next-check-grace">(grace until <%= mono_timestamp(monitor.due_with_grace_at) %>)</span>
      <% end %>
    </dd>
  <% else %>
    <span class="font-mono" data-testid="next-check">next in <%= humanize_duration_until(monitor.next_due_at) %></span>
  <% end %>
<% end %>
