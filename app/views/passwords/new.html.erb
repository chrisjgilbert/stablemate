<% content_for :title, "Forgot password" %>
<div class="max-w-sm mx-auto mt-8">
  <div class="flex flex-col items-center gap-3 mb-8 text-center">
    <%= render "shared/auth_logo" %>
    <h1 class="font-display text-2xl font-bold tracking-tight">Forgot your password?</h1>
    <p class="text-[13px] text-muted">We'll email you a link to set a new one.</p>
  </div>

  <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
    <% if alert = flash[:alert] %>
      <div class="mb-4 rounded-lg border border-down-bg bg-down-bg/60 px-3 py-2 text-[12px] text-down-text" id="alert" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <%= form_with url: passwords_path, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :email_address, "Email", class: "block text-[13px] font-medium text-secondary mb-1" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
              value: params[:email_address],
              class: "w-full h-[38px] px-3 rounded-lg border border-border font-mono text-[13px] focus:outline-brand" %>
      </div>
      <%= form.submit "Email reset instructions",
            class: "w-full h-[38px] rounded-lg bg-brand text-white text-[13px] font-semibold hover:bg-brand-hover cursor-pointer" %>
    <% end %>
  </div>

  <p class="mt-5 text-center text-[13px] text-secondary">
    Remembered it? <%= link_to "Sign in", sign_in_path, class: "text-brand font-medium" %>
  </p>
</div>
