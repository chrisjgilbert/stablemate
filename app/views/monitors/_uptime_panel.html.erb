<%#
  Detail "Uptime — last N days" panel (design-system.md §3): the UptimeBar fed
  real data from the rollups (Monitoring::Monitor::Uptime), trailed by the
  overall uptime %. The window is ping_retention_days (Stablemate::PING_RETENTION)
  so this panel, the landing page, and pruning can't drift apart.
  Locals: monitor.
%>
<% series = monitor.uptime_series(days: ping_retention_days) %>
<div class="rounded-xl border border-border bg-surface p-6 shadow-sm" data-testid="uptime-panel">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-[13px] font-semibold text-secondary">Uptime — last <%= ping_retention_days %> days</h2>
    <span class="font-mono text-[13px] text-ink" data-testid="uptime-percent">
      <%= uptime_percent_label(monitor.uptime_percent(days: ping_retention_days)) %>
    </span>
  </div>
  <%= render "shared/uptime_bar", days: uptime_bar_days(series) %>
</div>
