<!DOCTYPE html>
<html>
  <head>
    <%= render "layouts/head" %>

    <%# Newsreader is the one typeface unique to marketing; Zilla Slab + IBM Plex
        Mono now load once for the whole app via `layouts/_head`, and Newsreader
        ships in that same self-hosted app/assets/stylesheets/fonts.css. %>

    <%# All marketing CSS is scoped under `.lp` (see the wrapper below) so the
        authenticated app's design tokens are untouched. %>
    <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-app text-ink font-sans antialiased min-h-screen overflow-x-hidden">
    <% if notice %>
      <div class="rounded-none border-b border-up-bg bg-up-bg/60 px-4 py-2.5 text-center text-[13px] text-up-text" role="status">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="rounded-none border-b border-down-bg bg-down-bg/60 px-4 py-2.5 text-center text-[13px] text-down-text" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <div class="lp"><%= yield %></div>
  </body>
</html>
