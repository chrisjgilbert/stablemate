#!/usr/bin/env bash
# Stablemate CI — the single source of truth for "is this green?".
# Run locally (the pre-push hook calls this) and in GitHub Actions, so local and
# remote CI are identical. Defensive: the repo starts as docs only, so when the
# app isn't scaffolded yet this exits 0 instead of failing.
#
# Usage: bin/ci
set -uo pipefail

cd "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

bold() { printf '\033[1m%s\033[0m\n' "$*"; }
step() { printf '\n\033[1m→ %s\033[0m\n' "$*"; }

fail=0
note_fail() { fail=1; printf '\033[31m✗ %s failed\033[0m\n' "$1"; }

# --- Nothing to do until the app exists ------------------------------------
if [ ! -f Gemfile ]; then
  bold "bin/ci: no Gemfile yet — app not scaffolded. Nothing to check. ✓"
  exit 0
fi

bold "== Stablemate CI =="

# --- Dependencies ----------------------------------------------------------
if command -v bundle >/dev/null 2>&1; then
  step "bundle install"
  bundle check >/dev/null 2>&1 || bundle install || { echo "bundle install failed"; exit 1; }
fi

# --- Prepare the test database --------------------------------------------
if [ -f bin/rails ]; then
  step "db:prepare (RAILS_ENV=test)"
  RAILS_ENV=test bin/rails db:prepare || { echo "db:prepare failed"; exit 1; }
fi

# --- Lint ------------------------------------------------------------------
if bundle exec rubocop --version >/dev/null 2>&1; then
  step "rubocop"
  bundle exec rubocop || note_fail "rubocop"
fi

# --- Security --------------------------------------------------------------
if bundle exec brakeman --version >/dev/null 2>&1; then
  step "brakeman"
  bundle exec brakeman --quiet --no-pager -w2 || note_fail "brakeman"
fi
if bundle exec bundle-audit version >/dev/null 2>&1; then
  step "bundle-audit"
  # Ignore GHSA-mjgf-xj26-9qf9: a non-constant-time HMAC compare in Pay's PADDLE
  # webhook signature verifier. Stablemate is Stripe-only — no Paddle backend is
  # wired (config.enabled_processors is %i[stripe] or []), so that code path is
  # never loaded and there is no exposure. Revisit when we bump pay to the patched
  # 9.x+ line (a major upgrade, tracked separately), or if a Paddle processor is
  # ever added. Every other advisory still fails the build.
  bundle exec bundle-audit check --update --ignore GHSA-mjgf-xj26-9qf9 || note_fail "bundle-audit"
fi

# --- Tests -----------------------------------------------------------------
if [ -f bin/rails ]; then
  step "rails test (unit + request + job + mailer)"
  bin/rails test || note_fail "rails test"

  step "rails test:system (browser-driven, mandatory)"
  bin/rails test:system || note_fail "rails test:system"
fi

# --- Companion gem suite ---------------------------------------------------
# Runs the gem's own Minitest suite when gem/ is present (skipped only when the
# directory doesn't exist). The gem suite is a REQUIRED part of the gate and
# fails CLOSED: if the gem's deps can't be installed, `require "fugit"` raises
# and the run red-fails here — we never want to silently skip the gem suite. So
# a real gem test failure OR a gem dependency failure fails CI. Invoked directly
# via ruby (not `bundle exec rake`) so it's independent of the app's Bundler and
# of the Bundler 4 binstub quirk that hides bundled executables in this sandbox.
if [ -d gem ]; then
  step "stablemate gem tests"
  (
    cd gem
    # Best-effort install; if it fails the ruby run below still fails closed on
    # the missing dependency, so CI stays red rather than skipping the suite.
    bundle check >/dev/null 2>&1 || bundle install >/dev/null 2>&1 || true
    ruby -Ilib -Itest -e 'Dir["test/**/*_test.rb"].each { |f| require File.expand_path(f) }'
  ) || note_fail "gem tests"
fi

echo
if [ "$fail" -ne 0 ]; then
  bold "== CI FAILED =="
  exit 1
fi
bold "== CI PASSED =="
